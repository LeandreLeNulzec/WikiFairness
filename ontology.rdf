    </owl:ObjectProperty>
    


    <!-- http://www.fates-mlops/impactsNegatively -->

    <owl:ObjectProperty rdf:about="http://www.fates-mlops/impactsNegatively">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.fates-mlops/Element"/>
        <rdfs:range rdf:resource="http://www.fates-mlops/Domain"/>
    </owl:ObjectProperty>
    


    <!-- http://www.fates-mlops/impactsPositively -->

    <owl:ObjectProperty rdf:about="http://www.fates-mlops/impactsPositively">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.fates-mlops/isMeasuredBy -->

    <owl:ObjectProperty rdf:about="http://www.fates-mlops/isMeasuredBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.fates-mlops/refines -->

    <owl:ObjectProperty rdf:about="http://www.fates-mlops/refines">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.fates-mlops/Element"/>
        <rdfs:range rdf:resource="http://www.fates-mlops/Element"/>
        <rdfs:comment>Indicates that one Element refines, specializes, or operationalizes another Element.</rdfs:comment>
        <rdfs:label>refines</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.fates-mlops/validFor -->

    <owl:ObjectProperty rdf:about="http://www.fates-mlops/validFor">
