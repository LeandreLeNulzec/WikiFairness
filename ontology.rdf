    <!-- http://www.fates-mlops/Criteria -->

    <owl:Class rdf:about="http://www.fates-mlops/Criteria">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.fates-mlops/evaluates"/>
                        <owl:someValuesFrom rdf:resource="http://www.fates-mlops/Element"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.fates-mlops/isMeasuredBy"/>
                        <owl:someValuesFrom rdf:resource="http://www.fates-mlops/Metric"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.fates-mlops/validFor"/>
                        <owl:someValuesFrom rdf:resource="http://www.fates-mlops/Task"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.fates-mlops/Domain -->

    <owl:Class rdf:about="http://www.fates-mlops/Domain"/>
    


    <!-- http://www.fates-mlops/Element -->

    <owl:Class rdf:about="http://www.fates-mlops/Element">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.fates-mlops/impactsNegatively"/>
                        <owl:someValuesFrom rdf:resource="http://www.fates-mlops/Domain"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.fates-mlops/impactsPositively"/>
                        <owl:someValuesFrom rdf:resource="http://www.fates-mlops/Domain"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
    </owl:Class>
    


