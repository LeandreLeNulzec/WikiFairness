        <fates-mlops:refines rdf:resource="http://www.fates-mlops/bias"/>
    </owl:NamedIndividual>
    


    <!-- http://www.fates-mlops/SelectionBias -->

    <owl:NamedIndividual rdf:about="http://www.fates-mlops/SelectionBias">
